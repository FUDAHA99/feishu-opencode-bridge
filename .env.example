# ============================================
# 飞书应用配置 (从飞书开放平台获取)
# https://open.feishu.cn/
# ============================================

# 应用凭证 - 必填
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# 加密密钥和验证令牌 (HTTP 模式必填，WebSocket 模式可选)
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# 连接模式: WebSocket (默认) 或 HTTP
# WebSocket 模式: 无需公网 IP，推荐本地使用
# HTTP 模式: 需要公网 IP 或内网穿透
FEISHU_USE_WS=true

# ============================================
# OpenCode 服务器配置
# ============================================

# OpenCode 服务器地址 (默认值通常不需要修改)
OPENCODE_HOSTNAME=127.0.0.1
OPENCODE_PORT=4096

# ============================================
# HTTP 服务配置 (仅 HTTP 模式需要)
# ============================================

# 桥接服务监听端口
HTTP_PORT=3000
